# ---------------------------------------------------------------------------
# docker-backup.py – Configuration
# ---------------------------------------------------------------------------
# Copy this file to .env and adjust the values.
# curl -L https://github.com/rustic-rs/nightly/raw/main/rustic/rustic-nightly-x86_64-unknown-linux-gnu.tar.gz | tar zx --exclude="config" && mv rustic /usr/bin/ && chmod +x /usr/bin/rustic
# Path to the rustic binary
BACKUP_BIN=/usr/bin/rustic

# ---------------------------------------------------------------------------
# Backend – choose one: "webdav" or "s3"
# If omitted the script auto-detects based on which variables are set.
# ---------------------------------------------------------------------------
BACKEND_TYPE=s3

# ---------------------------------------------------------------------------
# WebDAV Backend
# ---------------------------------------------------------------------------
# Full WebDAV URL including optional credentials:
#   https://user:password@dav.example.com/remote.php/dav/files/user/backups
# WEBDAV_REPO=

# ---------------------------------------------------------------------------
# S3 Backend (works with AWS S3, MinIO, Wasabi, Backblaze B2, etc.)
# ---------------------------------------------------------------------------
S3_BUCKET=mein-backup-bucket
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_REGION=eu-central-1
S3_ACCESS_KEY=AKIA...
S3_SECRET_KEY=wJalr...

# Prefix (subfolder) inside the bucket – each container gets a subdirectory
# below this path, e.g. backups/host01/my-container
S3_PREFIX=backups/host01

# ---------------------------------------------------------------------------
# Notifications (optional) – https://github.com/Gurkengewuerz/shoutrrr-api
# ---------------------------------------------------------------------------
# SHOUTRRR_API=https://shoutrrr.example.com
# SHOUTRRR_TOKEN=mytoken

